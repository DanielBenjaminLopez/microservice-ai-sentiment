# Copiar este archivo a .env y configurar los valores
# Google Generative AI key
GEMINI_API_KEY=tu_api_key_aqui

# Django settings
DJANGO_SECRET_KEY=replace_me_with_a_secure_key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Frontend settings (development)
# URL where the React dev server runs (used by CORS/proxy expectations)
FRONTEND_URL=http://localhost:5173

# Frontend build output directory (when building for production)
FRONTEND_BUILD_DIR=static/dist

# Database (default uses sqlite)
DATABASE_URL=sqlite:///db.sqlite3
